# PostgreSQL - Neon serverless (https://neon.tech)
# Dùng connection string pooled (có -pooler) cho serverless.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT thuần (thay Clerk) - đổi sang chuỗi ngẫu nhiên dài khi triển khai thật.
JWT_SECRET="doi-sang-chuoi-ngau-nhien-dai-khi-trien-khai"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
CLIENT_URL="http://localhost:5173"

# Email (Nodemailer) - tùy chọn, dùng cho thông báo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="UMC Canteen <no-reply@umc.vn>"
